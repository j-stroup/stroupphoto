RewriteEngine On
RewriteBase /

# If the file or directory actually exists on the server, serve it normally
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Otherwise, send the request to index.php
RewriteRule ^([^/]+)/?$ index.php?page=$1 [L,QSA]

# Define the error document for direct Apache errors
ErrorDocument 404 /404.php

# ----------------------------------------------------------------------
# SECURITY HEADERS
# ----------------------------------------------------------------------

<IfModule mod_headers.c>
    # 1. Prevent Sniffing: Stops browsers from trying to guess the content-type
    Header set X-Content-Type-Options "nosniff"

    # 2. Prevent Framing: Protects against Clickjacking by forbidding the site in an iframe
    Header set X-Frame-Options "DENY"

    # 3. Referrer Policy: Don't leak your local paths when clicking external links
    Header set Referrer-Policy "strict-origin-when-cross-origin"

    # 4. Content Security Policy (CSP): The "Gold Standard"
    # This policy allows scripts/styles from your own domain and Google Fonts.
    # It DISALLOWS inline scripts (unless you add a nonce) to stop XSS.
    Header set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; frame-ancestors 'none';"

    # 5. Permissions Policy: Disables features you don't need (Camera, Mic, Geolocation)
    Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>